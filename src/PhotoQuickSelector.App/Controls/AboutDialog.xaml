<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="PhotoQuickSelector_App.Controls.AboutDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Uid="AboutDialog"
    Title="バージョン情報"
    PrimaryButtonText="ライセンス情報"
    CloseButtonText="閉じる"
    DefaultButton="Close">

    <!-- アプリ名・バージョン・著作権。バージョンはコードビハインドでアセンブリから設定（ハードコードしない）。
         「ライセンス情報」は PrimaryButton。ContentDialog の入れ子表示はクラッシュ要因のため、
         呼び出し側（PhotoStatusBar）が本ダイアログを閉じてから LicenseDialog を開く連鎖にする。 -->
    <StackPanel Width="420" Spacing="14" Orientation="Horizontal">
        <Image Source="ms-appx:///Assets/Square150x150Logo.scale-200.png"
               Width="72" Height="72" VerticalAlignment="Top" />
        <StackPanel Spacing="6">
            <TextBlock Text="PhotoQuickSelector" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <TextBlock x:Name="VersionText"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Text="Copyright © 2026 KOBAT" Margin="0,4,0,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Text="MIT License"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <HyperlinkButton x:Uid="About_GitHubLink" Content="GitHub リポジトリ" Margin="0,4,0,0" Padding="0"
                             NavigateUri="https://github.com/kobat/PhotoQuickSelector-rebuild" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
