<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog
    x:Class="PhotoQuickSelector_App.Controls.ShortcutsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ショートカット一覧"
    CloseButtonText="閉じる"
    DefaultButton="Close">

    <!-- キー操作のチートシート。グループ（カテゴリ）→項目（キー｜説明）をデータ駆動で表示する。
         ItemsSource はコードビハインドで ShortcutCheatSheet.Groups を流し込む。幅は ContentDialogMaxWidth を
         コードビハインドで広げる。キー列は固定幅で全行そろえ、説明はラップして 2 カラム表示。 -->
    <ScrollViewer Width="660" Height="560"
                  VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <ItemsControl x:Name="GroupsRepeater">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Text="{Binding Title}" Style="{ThemeResource SubtitleTextBlockStyle}"
                                   Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="210" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" HorizontalAlignment="Left"
                                                VerticalAlignment="Center" Margin="0,0,12,0"
                                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1" CornerRadius="6" Padding="8,2">
                                            <TextBlock Text="{Binding Keys}" FontFamily="Consolas"
                                                       FontSize="13" TextWrapping="Wrap" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding Description}"
                                                   TextWrapping="Wrap" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</ContentDialog>
