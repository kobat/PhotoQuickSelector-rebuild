<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PhotoQuickSelector_App.Controls.PreviewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PhotoQuickSelector_App.ViewModels"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="RightPanelColumn" Width="260" MinWidth="160" />
        </Grid.ColumnDefinitions>

        <!-- 左カラム: メイン大画面 ＋ フィルムストリップ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- メイン大画面プレビュー（Win2D） -->
            <canvas:CanvasControl
                x:Name="MainCanvas"
                Grid.Row="0"
                IsTabStop="True"
                UseSystemFocusVisuals="False"
                ClearColor="#1E1E1E"
                Draw="MainCanvas_Draw"
                CreateResources="MainCanvas_CreateResources"
                SizeChanged="MainCanvas_SizeChanged"
                PointerPressed="MainCanvas_PointerPressed"
                PointerMoved="MainCanvas_PointerMoved"
                PointerReleased="MainCanvas_PointerReleased"
                PointerWheelChanged="MainCanvas_PointerWheelChanged"
                DoubleTapped="MainCanvas_DoubleTapped" />

        <!-- フィルムストリップ（横スクロール） -->
        <ListView
            x:Name="FilmStrip"
            Grid.Row="1"
            Height="96"
            Padding="4"
            ItemsSource="{x:Bind ViewModel.Photos, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedPhoto, Mode=TwoWay}"
            SelectionMode="Single"
            ScrollViewer.HorizontalScrollMode="Enabled"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.VerticalScrollMode="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="2" />
                    <Setter Property="MinWidth" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:PhotoItemViewModel">
                    <Image
                        Width="78"
                        Height="78"
                        Source="{x:Bind Thumbnail, Mode=OneWay}"
                        Stretch="Uniform" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        </Grid>

        <!-- 左カラムと右パネルのリサイズ用スプリッター -->
        <controls:GridSplitter
            Grid.Column="1"
            Width="8"
            ResizeBehavior="BasedOnAlignment"
            ResizeDirection="Auto" />

        <!-- 右カラム: 上=ズームプレビュー(ルーペ) / 下=ナビゲーター -->
        <Grid Grid.Column="2" Background="#252525">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="80" />
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="NavRow" Height="220" MinHeight="100" />
            </Grid.RowDefinitions>

            <!-- ズームプレビュー（100% ルーペ。独立スクロール） -->
            <canvas:CanvasControl
                x:Name="ZoomCanvas"
                Grid.Row="0"
                ClearColor="#1E1E1E"
                Draw="ZoomCanvas_Draw"
                CreateResources="SubCanvas_CreateResources"
                SizeChanged="ZoomCanvas_SizeChanged"
                PointerPressed="ZoomCanvas_PointerPressed"
                PointerMoved="ZoomCanvas_PointerMoved"
                PointerReleased="ZoomCanvas_PointerReleased"
                PointerWheelChanged="ZoomCanvas_PointerWheelChanged" />

            <!-- ズームプレビューとナビゲーターのリサイズ用スプリッター -->
            <controls:GridSplitter
                Grid.Row="1"
                Height="8"
                HorizontalAlignment="Stretch"
                ResizeBehavior="BasedOnAlignment"
                ResizeDirection="Auto" />

            <!-- ナビゲーター（全体縮小画像＋表示領域矩形＋AF枠） -->
            <canvas:CanvasControl
                x:Name="NavCanvas"
                Grid.Row="2"
                ClearColor="#2A2A2A"
                Draw="NavCanvas_Draw"
                CreateResources="SubCanvas_CreateResources"
                SizeChanged="NavCanvas_SizeChanged"
                PointerPressed="NavCanvas_PointerPressed"
                PointerMoved="NavCanvas_PointerMoved"
                PointerReleased="NavCanvas_PointerReleased" />
        </Grid>
    </Grid>
</UserControl>
