<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PhotoQuickSelector_App.Controls.PreviewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PhotoQuickSelector_App.ViewModels"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="RightPanelColumn" Width="260" MinWidth="160" />
        </Grid.ColumnDefinitions>

        <!-- 左カラム: メイン大画面 ＋ フィルムストリップ -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- メイン大画面プレビュー（Win2D） -->
            <canvas:CanvasControl
                x:Name="MainCanvas"
                Grid.Row="0"
                IsTabStop="True"
                UseSystemFocusVisuals="False"
                ClearColor="#1E1E1E"
                Draw="MainCanvas_Draw"
                CreateResources="MainCanvas_CreateResources"
                SizeChanged="MainCanvas_SizeChanged"
                PointerPressed="MainCanvas_PointerPressed"
                PointerMoved="MainCanvas_PointerMoved"
                PointerReleased="MainCanvas_PointerReleased"
                PointerWheelChanged="MainCanvas_PointerWheelChanged"
                DoubleTapped="MainCanvas_DoubleTapped" />

            <!-- メタ情報オーバーレイ（案B / I キーでトグル）。画像領域を狭めず左上に半透明で重畳。
                 ポインタは透過させてズーム/パン操作を妨げない。
                 DataContext=選択写真。内部はクラシック Binding（null セーフ＝WUI2010 回避、評価のライブ更新も追従）。 -->
            <Border Grid.Row="0"
                    VerticalAlignment="Top" HorizontalAlignment="Left"
                    Margin="12" Padding="12,9" CornerRadius="8"
                    Background="#A6000000" IsHitTestVisible="False"
                    DataContext="{x:Bind ViewModel.SelectedPhoto, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.InfoOverlayVisibility, Mode=OneWay}">
                <StackPanel Spacing="6" MaxWidth="440">
                    <!-- 1行目: ファイル名 ＋ 画像サイズ ＋ ファイルサイズ -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding FileName}"
                                   Foreground="White" FontSize="13" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding ImageSizeText}"
                                   Foreground="#BFFFFFFF" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding FileSizeText}"
                                   Foreground="#BFFFFFFF" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- 2行目: EXIF 撮影設定チップ（焦点距離/絞り/SS/露出補正/ISO） -->
                    <ItemsControl ItemsSource="{Binding ExifChips}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1FFFFFFF" CornerRadius="9" Padding="7,2">
                                    <TextBlock Text="{Binding}" Foreground="#E8FFFFFF" FontSize="11" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 3行目: カメラ / レンズ -->
                    <TextBlock Text="{Binding CameraLensText}"
                               Foreground="#9AFFFFFF" FontSize="11"
                               TextTrimming="CharacterEllipsis" />

                    <!-- 4行目: 評価（★/旗/カラー） ＋ 撮影日時 -->
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{Binding RatingStars}"
                                   Foreground="{Binding RatingForeground}"
                                   FontSize="12" VerticalAlignment="Center"
                                   Visibility="{Binding RatingVisibility}" />
                        <Grid VerticalAlignment="Center"
                              Visibility="{Binding FlagVisibility}">
                            <FontIcon Glyph="&#xE7C1;" FontSize="12" Foreground="LimeGreen"
                                      Visibility="{Binding PickVisibility}" />
                            <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="OrangeRed"
                                      Visibility="{Binding RejectVisibility}" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center"
                                    Visibility="{Binding ColorDotsVisibility}">
                            <Ellipse Width="9" Height="9" Fill="#E53935"
                                     Visibility="{Binding RedVisibility}" />
                            <Ellipse Width="9" Height="9" Fill="#FDD835"
                                     Visibility="{Binding YellowVisibility}" />
                            <Ellipse Width="9" Height="9" Fill="#43A047"
                                     Visibility="{Binding GreenVisibility}" />
                            <Ellipse Width="9" Height="9" Fill="#1E88E5"
                                     Visibility="{Binding BlueVisibility}" />
                            <Ellipse Width="9" Height="9" Fill="#8E24AA"
                                     Visibility="{Binding PurpleVisibility}" />
                        </StackPanel>
                        <TextBlock Text="{Binding TakenDateTimeText}"
                                   Foreground="#8AFFFFFF" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

        <!-- フィルムストリップ（横スクロール） -->
        <ListView
            x:Name="FilmStrip"
            Grid.Row="1"
            Height="118"
            Padding="4"
            ItemsSource="{x:Bind ViewModel.Photos, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedPhoto, Mode=TwoWay}"
            SelectionMode="Single"
            ScrollViewer.HorizontalScrollMode="Enabled"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.VerticalScrollMode="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="2" />
                    <Setter Property="MinWidth" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:PhotoItemViewModel">
                    <StackPanel Width="88">
                        <!-- カラーラベル＝枠線。透明時も 3px 確保しレイアウトを安定させる -->
                        <Border CornerRadius="4" BorderThickness="3"
                                BorderBrush="{x:Bind ColorLabelBorderBrush, Mode=OneWay}">
                            <Grid Width="84" Height="84"
                                  Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <Image Source="{x:Bind Thumbnail, Mode=OneWay}" Stretch="Uniform" />

                                <!-- 旗バッジ（左上）：採用=旗 / 拒否=×。正方形 -->
                                <Border VerticalAlignment="Top" HorizontalAlignment="Left"
                                        Margin="3" Width="20" Height="20" CornerRadius="3"
                                        Background="#99000000"
                                        Visibility="{x:Bind FlagVisibility, Mode=OneWay}">
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE7C1;" FontSize="11" Foreground="LimeGreen"
                                                  Visibility="{x:Bind PickVisibility, Mode=OneWay}" />
                                        <FontIcon Glyph="&#xE711;" FontSize="11" Foreground="OrangeRed"
                                                  Visibility="{x:Bind RejectVisibility, Mode=OneWay}" />
                                    </Grid>
                                </Border>

                                <!-- 色ドット（右上）：高さは旗と同じ、単一色は正方形 -->
                                <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                        Margin="3" Height="20" MinWidth="20" Padding="4,0" CornerRadius="3"
                                        Background="#99000000"
                                        Visibility="{x:Bind ColorDotsVisibility, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="2"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" Fill="#E53935"
                                                 Visibility="{x:Bind RedVisibility, Mode=OneWay}" />
                                        <Ellipse Width="8" Height="8" Fill="#FDD835"
                                                 Visibility="{x:Bind YellowVisibility, Mode=OneWay}" />
                                        <Ellipse Width="8" Height="8" Fill="#43A047"
                                                 Visibility="{x:Bind GreenVisibility, Mode=OneWay}" />
                                        <Ellipse Width="8" Height="8" Fill="#1E88E5"
                                                 Visibility="{x:Bind BlueVisibility, Mode=OneWay}" />
                                        <Ellipse Width="8" Height="8" Fill="#8E24AA"
                                                 Visibility="{x:Bind PurpleVisibility, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>

                                <!-- 下部中央：★レーティング（色ドットと同形の黒バッジ） -->
                                <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                        Margin="0,0,0,2" Height="20" MinWidth="20" Padding="4,0"
                                        CornerRadius="3" Background="#99000000"
                                        Visibility="{x:Bind RatingVisibility, Mode=OneWay}">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="{x:Bind RatingForeground, Mode=OneWay}"
                                               Text="{x:Bind RatingStars, Mode=OneWay}" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- ファイル名（画像の下の独立行） -->
                        <TextBlock Text="{x:Bind FileName}" FontSize="10"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   MaxWidth="88" Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        </Grid>

        <!-- 左カラムと右パネルのリサイズ用スプリッター -->
        <controls:GridSplitter
            Grid.Column="1"
            Width="8"
            ResizeBehavior="BasedOnAlignment"
            ResizeDirection="Auto" />

        <!-- 右カラム: 上=ズームプレビュー(ルーペ) / 下=ナビゲーター -->
        <Grid Grid.Column="2" Background="#252525">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="80" />
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="NavRow" Height="220" MinHeight="100" />
            </Grid.RowDefinitions>

            <!-- ズームプレビュー（100% ルーペ。独立スクロール） -->
            <canvas:CanvasControl
                x:Name="ZoomCanvas"
                Grid.Row="0"
                ClearColor="#1E1E1E"
                Draw="ZoomCanvas_Draw"
                CreateResources="SubCanvas_CreateResources"
                SizeChanged="ZoomCanvas_SizeChanged"
                PointerPressed="ZoomCanvas_PointerPressed"
                PointerMoved="ZoomCanvas_PointerMoved"
                PointerReleased="ZoomCanvas_PointerReleased"
                PointerWheelChanged="ZoomCanvas_PointerWheelChanged" />

            <!-- ズームプレビューとナビゲーターのリサイズ用スプリッター -->
            <controls:GridSplitter
                Grid.Row="1"
                Height="8"
                HorizontalAlignment="Stretch"
                ResizeBehavior="BasedOnAlignment"
                ResizeDirection="Auto" />

            <!-- ナビゲーター（全体縮小画像＋表示領域矩形＋AF枠） -->
            <canvas:CanvasControl
                x:Name="NavCanvas"
                Grid.Row="2"
                ClearColor="#2A2A2A"
                Draw="NavCanvas_Draw"
                CreateResources="SubCanvas_CreateResources"
                SizeChanged="NavCanvas_SizeChanged"
                PointerPressed="NavCanvas_PointerPressed"
                PointerMoved="NavCanvas_PointerMoved"
                PointerReleased="NavCanvas_PointerReleased" />
        </Grid>
    </Grid>
</UserControl>
