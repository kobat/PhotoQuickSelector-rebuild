<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PhotoQuickSelector_App.Controls.PreviewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PhotoQuickSelector_App.ViewModels"
    xmlns:ctl="using:PhotoQuickSelector_App.Controls"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- フィルムストリップのサムネイル寸法（高さ調節に追従）。各セルが Source バインドで参照する。 -->
        <ctl:FilmStripMetrics x:Key="FilmMetrics" />
    </UserControl.Resources>

    <Grid Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition x:Name="FilmStripRow" Height="118" MinHeight="80" MaxHeight="220" />
        </Grid.RowDefinitions>

        <!-- 上段: メイン大画面（左）＋ ズームプレビュー/ナビゲーター（右） -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition x:Name="RightPanelColumn" Width="260" MinWidth="160" />
            </Grid.ColumnDefinitions>

            <!-- 左カラム: メイン大画面プレビュー（Win2D） -->
            <canvas:CanvasControl
                x:Name="MainCanvas"
                Grid.Column="0"
                IsTabStop="True"
                UseSystemFocusVisuals="False"
                ClearColor="Transparent"
                Draw="MainCanvas_Draw"
                CreateResources="MainCanvas_CreateResources"
                SizeChanged="MainCanvas_SizeChanged"
                PointerPressed="MainCanvas_PointerPressed"
                PointerMoved="MainCanvas_PointerMoved"
                PointerReleased="MainCanvas_PointerReleased"
                PointerWheelChanged="MainCanvas_PointerWheelChanged"
                Tapped="MainCanvas_Tapped"
                DoubleTapped="MainCanvas_DoubleTapped" />

            <!-- メタ情報オーバーレイ（案B / I キーでトグル）。画像領域を狭めず左上に半透明で重畳。
                 ポインタは透過させてズーム/パン操作を妨げない。
                 DataContext=選択写真。内部はクラシック Binding（null セーフ＝WUI2010 回避、評価のライブ更新も追従）。 -->
            <Border Grid.Column="0"
                    VerticalAlignment="Top" HorizontalAlignment="Left"
                    Margin="12" Padding="12,9" CornerRadius="8"
                    Background="#A6000000" IsHitTestVisible="False"
                    DataContext="{x:Bind ViewModel.FocusedPhoto, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.InfoOverlayVisibility, Mode=OneWay}">
                <StackPanel Spacing="6" MaxWidth="440">
                    <!-- 1行目: ファイル名 ＋ 画像サイズ ＋ ファイルサイズ -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding FileName}"
                                   Foreground="White" FontSize="13" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding ImageSizeText}"
                                   Foreground="#BFFFFFFF" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding FileSizeText}"
                                   Foreground="#BFFFFFFF" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- 2行目: EXIF 撮影設定チップ（焦点距離/絞り/SS/露出補正/ISO） -->
                    <ItemsControl ItemsSource="{Binding ExifChips}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1FFFFFFF" CornerRadius="9" Padding="7,2">
                                    <TextBlock Text="{Binding}" Foreground="#E8FFFFFF" FontSize="11" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 3行目: カメラ / レンズ -->
                    <TextBlock Text="{Binding CameraLensText}"
                               Foreground="#9AFFFFFF" FontSize="11"
                               TextTrimming="CharacterEllipsis" />

                    <!-- 4行目: 評価（★/旗/カラー） ＋ 撮影日時 -->
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{Binding RatingStars}"
                                   Foreground="{Binding RatingForeground}"
                                   FontSize="12" VerticalAlignment="Center"
                                   Visibility="{Binding RatingVisibility}" />
                        <ctl:FlagGlyph GlyphSize="12" VerticalAlignment="Center"
                                       Visibility="{Binding FlagVisibility}" />
                        <ctl:ColorLabelDots DotSize="9" Spacing="3" VerticalAlignment="Center"
                                            Visibility="{Binding ColorDotsVisibility}" />
                        <TextBlock Text="{Binding TakenDateTimeText}"
                                   Foreground="#8AFFFFFF" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 先読みキャッシュ内容のデバッグオーバーレイ（C キーでトグル / 初期非表示）。
                 右上に半透明で重畳し、ポインタは透過させて操作を妨げない。 -->
            <Border x:Name="CacheOverlay" Grid.Column="0"
                    VerticalAlignment="Top" HorizontalAlignment="Right"
                    Margin="12" Padding="10,8" CornerRadius="8"
                    Background="#A6000000" IsHitTestVisible="False"
                    Visibility="Collapsed">
                <StackPanel Spacing="3" MaxWidth="460">
                    <TextBlock x:Uid="Preview_CacheOverlayHeader" Text="先読みキャッシュ" Foreground="#BFFFFFFF"
                               FontSize="11" FontWeight="SemiBold" />
                    <TextBlock x:Name="CacheOverlaySummary" Foreground="#E8FFFFFF" FontSize="11" FontFamily="Consolas" />
                    <ItemsControl ItemsSource="{x:Bind CachedFileNames, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="ctl:CacheEntry">
                                <TextBlock Text="{x:Bind Text}" Foreground="{x:Bind Foreground}"
                                           FontSize="11" FontFamily="Consolas" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- 左カラムと右パネルのリサイズ用スプリッター -->
            <controls:GridSplitter
                x:Name="RightSplitter"
                Grid.Column="1"
                Width="8"
                ResizeBehavior="BasedOnAlignment"
                ResizeDirection="Auto" />

            <!-- 右カラム: 上=ズームプレビュー(ルーペ)⇄EXIF詳細（タブ/E キーで切替） / 下=ナビゲーター -->
            <Grid x:Name="RightPanel" Grid.Column="2"
                  Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                  SizeChanged="RightPanel_SizeChanged">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" MinHeight="80" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="NavRow" Height="220" MinHeight="100" />
                </Grid.RowDefinitions>

                <!-- 上段の表示切替タブ（ルーペ / EXIF）。IsTabStop=False でクリックしてもフォーカスを奪わず、
                     キー操作（←/→ 等のグローバル集約）を妨げない -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Padding="6,4,6,2">
                    <ToggleButton x:Name="LoupeTabButton" x:Uid="Preview_LoupeTab"
                                  FontSize="11" Padding="12,4" MinHeight="0" IsTabStop="False"
                                  IsChecked="True" Click="LoupeTabButton_Click" />
                    <ToggleButton x:Name="ExifTabButton" x:Uid="Preview_ExifTab"
                                  FontSize="11" Padding="12,4" MinHeight="0" IsTabStop="False"
                                  Click="ExifTabButton_Click" />
                </StackPanel>

                <!-- ズームプレビュー（100% ルーペ。独立スクロール） -->
                <canvas:CanvasControl
                    x:Name="ZoomCanvas"
                    Grid.Row="1"
                    ClearColor="Transparent"
                    Draw="ZoomCanvas_Draw"
                    CreateResources="SubCanvas_CreateResources"
                    SizeChanged="ZoomCanvas_SizeChanged"
                    PointerPressed="ZoomCanvas_PointerPressed"
                    PointerMoved="ZoomCanvas_PointerMoved"
                    PointerReleased="ZoomCanvas_PointerReleased"
                    PointerWheelChanged="ZoomCanvas_PointerWheelChanged" />

                <!-- EXIF 詳細（ルーペと同一セルで排他表示。内容の供給は PreviewControl.ExifPanel.cs） -->
                <ctl:ExifDetailPanel x:Name="ExifPanel" Grid.Row="1" Visibility="Collapsed" />

                <!-- ズームプレビューとナビゲーターのリサイズ用スプリッター -->
                <controls:GridSplitter
                    Grid.Row="2"
                    Height="8"
                    HorizontalAlignment="Stretch"
                    ResizeBehavior="BasedOnAlignment"
                    ResizeDirection="Auto" />

                <!-- ナビゲーター（全体縮小画像＋表示領域矩形＋AF枠） -->
                <canvas:CanvasControl
                    x:Name="NavCanvas"
                    Grid.Row="3"
                    ClearColor="Transparent"
                    Draw="NavCanvas_Draw"
                    CreateResources="SubCanvas_CreateResources"
                    SizeChanged="NavCanvas_SizeChanged"
                    PointerPressed="NavCanvas_PointerPressed"
                    PointerMoved="NavCanvas_PointerMoved"
                    PointerReleased="NavCanvas_PointerReleased" />
            </Grid>
        </Grid>

        <!-- 上段とフィルムストリップの境界リサイズ用スプリッター（高さ調節） -->
        <controls:GridSplitter
            x:Name="FilmSplitter"
            Grid.Row="1"
            Height="8"
            HorizontalAlignment="Stretch"
            ResizeBehavior="BasedOnAlignment"
            ResizeDirection="Auto" />

        <!-- 下段: フィルムストリップ（横スクロール・右端まで全幅・高さは行に追従） -->
        <!-- VM→ビューは OneWay バインド、ビュー→VM は SelectionChanged で反映（修飾クリック対応のため。
             二重更新はコードビハインドのエコー判定で防ぐ）。 -->
        <ListView
            x:Name="FilmStrip"
            Grid.Row="2"
            Padding="4,0,4,2"
            SizeChanged="FilmStrip_SizeChanged"
            ItemsSource="{x:Bind ViewModel.Photos, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.FocusedPhoto, Mode=OneWay}"
            SelectionChanged="FilmStrip_SelectionChanged"
            SelectionMode="Single"
            ScrollViewer.HorizontalScrollMode="Enabled"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.VerticalScrollMode="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Disabled"
            ContainerContentChanging="FilmStrip_ContainerContentChanging"
            DoubleTapped="FilmStrip_DoubleTapped"
            RightTapped="FilmStrip_RightTapped">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="2,0" />
                    <Setter Property="MinWidth" Value="0" />
                    <!-- 既定のキーボードフォーカス枠（矩形）を無効化。選択強調は案2のアクセント外枠で行う -->
                    <Setter Property="UseSystemFocusVisuals" Value="False" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:PhotoItemViewModel">
                    <!-- 非焦点かつ非メンバーのセルを CellOpacity(0.9) で淡くし、焦点/メンバーは全不透明にする -->
                    <StackPanel Width="{Binding ItemWidth, Source={StaticResource FilmMetrics}}"
                                Opacity="{x:Bind CellOpacity, Mode=OneWay}">
                        <!-- セル本体（カラーラベル枠＋画像＋バッジ）に、最外周のアクセント外枠を重ねる。
                             外枠は子を持たない空リングなので Opacity=0（非選択）でも画像は消えない。 -->
                        <Grid>
                        <!-- カラーラベル＝枠線。透明時も 3px 確保しレイアウトを安定させる。
                             Margin=3 でアクセント外枠ぶんを外周に空ける。 -->
                        <Border Margin="3" CornerRadius="4" BorderThickness="3"
                                BorderBrush="{x:Bind ColorLabelBorderBrush, Mode=OneWay}">
                            <Grid Width="{Binding Edge, Source={StaticResource FilmMetrics}}"
                                  Height="{Binding Edge, Source={StaticResource FilmMetrics}}"
                                  Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <!-- Source はバインドせず、ContainerContentChanging で可視分だけ生成/破棄する -->
                                <Image x:Name="FilmThumbImage" Stretch="Uniform" />

                                <!-- 旗バッジ（左上）：採用=旗 / 拒否=×。正方形 -->
                                <Border VerticalAlignment="Top" HorizontalAlignment="Left"
                                        Margin="3" Width="20" Height="20" CornerRadius="3"
                                        Background="#99000000"
                                        Visibility="{x:Bind FlagVisibility, Mode=OneWay}">
                                    <ctl:FlagGlyph GlyphSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- 色ドット（右上）：高さは旗と同じ、単一色は正方形 -->
                                <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                        Margin="3" Height="20" MinWidth="20" Padding="4,0" CornerRadius="3"
                                        Background="#99000000"
                                        Visibility="{x:Bind ColorDotsVisibility, Mode=OneWay}">
                                    <ctl:ColorLabelDots DotSize="8" Spacing="2"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- 下部中央：★レーティング（色ドットと同形の黒バッジ） -->
                                <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                        Margin="0,0,0,2" Height="20" MinWidth="20" Padding="4,0"
                                        CornerRadius="3" Background="#99000000"
                                        Visibility="{x:Bind RatingVisibility, Mode=OneWay}">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="{x:Bind RatingForeground, Mode=OneWay}"
                                               Text="{x:Bind RatingStars, Mode=OneWay}" />
                                </Border>
                            </Grid>
                        </Border>
                        <!-- 焦点のアクセント外枠（案A＝「枠」チャンネル・くっきり純白）。セル本体に重ね最外周へ描画。
                             焦点時のみ FocusFrameOpacity(1.0) で可視。子が無いので Opacity=0 でも画像は残る。
                             枠は常設しレイアウト不変。カラーラベル枠（内側）とは別レイヤで併存。
                             メンバーの塗りウォッシュより明るく強い縁取りになるよう純白（#FFFFFFFF）にする。 -->
                        <Border CornerRadius="6" BorderThickness="3"
                                BorderBrush="#FFFFFFFF"
                                IsHitTestVisible="False"
                                Opacity="{x:Bind FocusFrameOpacity, Mode=OneWay}" />
                        <!-- 選択集合メンバーのハイライト（案A＝「塗りウォッシュ」チャンネル）。半透明白の背景ウォッシュ
                             主体で「集合の一員」を示し、縁取りは 1px の淡い白のみ。焦点の純白枠（外周）と競合しないよう
                             太い枠は使わない。ウォッシュは薄め（#33FFFFFF＝20%）にして写真の発色を残す（濃いと「色あせ＝
                             削除」に見える）。焦点リングの内側に別レイヤで重ね、メンバー時のみ可視。 -->
                        <Border CornerRadius="5" BorderThickness="1" Margin="1"
                                BorderBrush="#FFFFFFFF" Background="#33FFFFFF"
                                IsHitTestVisible="False"
                                Opacity="{x:Bind SelectionHighlightOpacity, Mode=OneWay}" />
                        </Grid>

                        <!-- ファイル名（画像の下の独立行） -->
                        <TextBlock Text="{x:Bind FileName}" FontSize="10"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   MaxWidth="{Binding ItemWidth, Source={StaticResource FilmMetrics}}"
                                   Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
