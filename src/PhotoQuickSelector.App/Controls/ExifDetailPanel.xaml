<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PhotoQuickSelector_App.Controls.ExifDetailPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:core="using:PhotoQuickSelector.Core"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!-- グループ化ソース。コードビハインドから Source に ExifTagGroup のリストを代入する。
             ItemsPath=Tags で各グループの子要素（ExifTagEntry）を取り出す。 -->
        <CollectionViewSource x:Name="GroupedTagsSource"
                               IsSourceGrouped="True"
                               ItemsPath="Tags" />
    </UserControl.Resources>

    <!-- (a) グループ化 ListView と (b) メッセージ表示を重ねる。ShowTags/ShowMessage で片方だけ見せる。 -->
    <Grid>
        <!-- タグ総数が数百〜千超のこともあるため必ず仮想化 ListView を使う（非仮想化 ItemsControl 禁止）。 -->
        <ListView x:Name="TagListView"
                  ItemsSource="{Binding Source={StaticResource GroupedTagsSource}}"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.HorizontalScrollMode="Disabled"
                  Padding="4,0">
            <ListView.ItemContainerStyle>
                <!-- 行を高密度化（既定の ListViewItem は縦の余白が大きすぎる）。 -->
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="4,1" />
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="core:ExifTagEntry">
                    <Grid ColumnDefinitions="110,*">
                        <TextBlock Grid.Column="0"
                                   Text="{x:Bind Name}"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,8,0" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Description}"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   TextWrapping="Wrap"
                                   IsTextSelectionEnabled="True" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderContainerStyle>
                        <!-- 既定のグループヘッダーコンテナは縦に大きすぎるため詰める。 -->
                        <Style TargetType="ListViewHeaderItem">
                            <Setter Property="Padding" Value="4,6,4,2" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </GroupStyle.HeaderContainerStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate x:DataType="core:ExifTagGroup">
                            <TextBlock Text="{x:Bind DirectoryName}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
        </ListView>

        <!-- メッセージ表示（「EXIF なし」等）。文言は呼び出し側が渡す＝本コントロールは resw を持たない。 -->
        <TextBlock x:Name="MessageText"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="16"
                   FontSize="12"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Visibility="Collapsed" />
    </Grid>
</UserControl>
