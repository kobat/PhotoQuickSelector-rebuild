<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="PhotoQuickSelector_App.Controls.PhotoStatusBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ctl="using:PhotoQuickSelector_App.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- ステータスバー（2段組）。左=開閉ボタン＋ステータス（フォルダパス・読み込み中/エラー等）、右=選択写真のメタ情報を右寄せで密集表示。
         枚数はフィルタボタンの件数表示（FilteredCountText）と重複するためステータスには出さない。
         開閉ボタンは LeftColumn（骨組み側）を操作するため ToggleLeftPaneRequested イベントで MainPage へ委譲。 -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <!-- 左ペイン開閉。グリフ/ツールチップは実際の開閉状態に追従（MainPage が幅変化で UpdateLeftPaneGlyph を呼ぶ） -->
        <!-- ツールチップは開閉状態に応じてコードビハインド（UpdateLeftPaneGlyph）が Loc キーで設定する -->
        <Button Grid.Column="0" x:Name="LeftPaneButton" Click="ToggleButton_Click" Margin="0,0,8,0"
                Height="32" Width="32" Padding="0" VerticalAlignment="Center">
            <FontIcon x:Name="LeftPaneIcon" Glyph="&#xE8A0;" FontSize="14" />
        </Button>
        <!-- フィルタボタン（開閉ボタンとステータステキストの間）。件数表示はこのボタン内（FilteredCountText）に集約。 -->
        <ctl:FilterBar Grid.Column="1" x:Name="FilterControl" Margin="0,0,8,0" />
        <!-- ステータス表示。パスモード時は末尾フォルダ名（tail）を Auto 列で常時保証し、親ディレクトリ部（head）側を末尾省略する
             （CharacterEllipsis は末尾から削るため、単一 TextBlock だと一番重要な末尾フォルダ名から消える）。
             内側 Grid の HorizontalAlignment=Left により、幅が足りる時は head と tail が隣接し、不足時のみ * 列の head が縮む。 -->
        <Grid Grid.Column="2" VerticalAlignment="Center">
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                       Visibility="{x:Bind ViewModel.StatusMessageVisibility, Mode=OneWay}"
                       ToolTipService.ToolTip="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
            <Grid HorizontalAlignment="Left" VerticalAlignment="Center"
                  Visibility="{x:Bind ViewModel.StatusPathVisibility, Mode=OneWay}"
                  ToolTipService.ToolTip="{x:Bind ViewModel.StatusText, Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Bind ViewModel.StatusPathHead, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.StatusPathTail, Mode=OneWay}"
                           VerticalAlignment="Center" />
            </Grid>
        </Grid>

        <!-- メタ情報パネル（2段・右寄せ）。DataContext=選択写真、内部はクラシック Binding（null セーフ）。 -->
        <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="3" Margin="12,0"
                    DataContext="{x:Bind ViewModel.FocusedPhoto, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.PhotoInfoVisibility, Mode=OneWay}">
            <!-- 上段: 左=ファイル名 · 画像サイズ · ファイルサイズ（左寄せ）／右=EXIFチップ（右寄せ）。
                 1 行内で左右に分離するため Grid（* + Auto）。* 列が間を押し広げ、左グループは左端・EXIF は右端へ。
                 下段も同構造のため、どちらが広くても左端・右端が揃う。 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                            HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ImageSizeText}" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{Binding FileSizeText}" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ItemsControl Grid.Column="1" ItemsSource="{Binding ExifChips}"
                              HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="9" Padding="7,1">
                                <TextBlock Text="{Binding}" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>

            <!-- 下段: 左=カメラ/レンズ（左寄せ）／右=評価 · GPS · 撮影日時（右寄せ）。
                 上段と同じ Grid（* + Auto）構造。上段が下段より広いケースでもカメラ/レンズは左端・評価から右端へ。 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding CameraLensText}"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="{Binding RatingStars}" VerticalAlignment="Center"
                                   Foreground="{Binding RatingForeground}"
                                   Visibility="{Binding RatingVisibility}" />
                        <ctl:FlagGlyph GlyphSize="12" VerticalAlignment="Center"
                                       Visibility="{Binding FlagVisibility}" />
                        <ctl:ColorLabelDots DotSize="10" Spacing="3" VerticalAlignment="Center"
                                            Visibility="{Binding ColorDotsVisibility}" />
                    </StackPanel>
                    <!-- GPS 地図ボタン（位置情報があるときだけ表示。クリックで地図を開く） -->
                    <Button Click="GpsButton_Click" Padding="7,1" MinWidth="0"
                            VerticalAlignment="Center"
                            Visibility="{Binding GpsVisibility}"
                            ToolTipService.ToolTip="{Binding GpsTooltip}">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE81D;" FontSize="13"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            <TextBlock Text="GPS" FontSize="12"
                                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{Binding TakenDateTimeText}" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </StackPanel>

        <ProgressRing Grid.Column="4" Width="20" Height="20" VerticalAlignment="Center"
                      IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

        <!-- 倍率（プレビュー時のみ。ピクセル等倍＝100%。全画面ボタンの隣） -->
        <TextBlock Grid.Column="5" x:Uid="StatusBar_ZoomText" VerticalAlignment="Center" Margin="8,0,0,0"
                   MinWidth="44" TextAlignment="Right"
                   Text="{x:Bind ViewModel.ZoomText, Mode=OneWay}"
                   Visibility="{x:Bind ViewModel.ZoomVisibility, Mode=OneWay}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   ToolTipService.ToolTip="表示倍率（ピクセル等倍＝100%）" />

        <!-- 全画面表示の切替ボタン（F11 と同じ。AppWindow を操作するため MainWindow へ委譲） -->
        <Button Grid.Column="6" x:Uid="StatusBar_FullScreenButton"
                Click="FullScreenButton_Click" Margin="8,0,0,0"
                Height="32" Width="32" Padding="0" VerticalAlignment="Center"
                ToolTipService.ToolTip="全画面表示の切替 (F11)">
            <FontIcon Glyph="&#xE740;" FontSize="14" />
        </Button>

        <!-- メニュー（ハンバーガー）。設定・各種トグル・ファイル連携をショートカット付きで集約。
             歯車ボタンは廃止し「設定…」をこのメニューへ集約した。各項目はクリックでも実行可能。
             KeyboardAcceleratorTextOverride は表示専用（実キー処理は MainWindow の RootGrid 集約のまま）。 -->
        <Button Grid.Column="7" x:Uid="StatusBar_MenuButton" Margin="8,0,0,0"
                Height="32" Width="32" Padding="0" VerticalAlignment="Center"
                ToolTipService.ToolTip="メニュー">
            <FontIcon Glyph="&#xE700;" FontSize="14" />
            <Button.Flyout>
                <MenuFlyout Opening="Menu_Opening">
                    <ToggleMenuFlyoutItem x:Name="FilterToggleItem" x:Uid="Menu_FilterToggle"
                                          Text="フィルタ ON/OFF"
                                          KeyboardAcceleratorTextOverride="Ctrl+L"
                                          Click="MenuFilter_Click" />
                    <ToggleMenuFlyoutItem x:Name="FullScreenToggleItem" x:Uid="Menu_FullScreenToggle"
                                          Text="全画面表示"
                                          KeyboardAcceleratorTextOverride="F11"
                                          Click="MenuFullScreen_Click" />
                    <MenuFlyoutItem x:Uid="Menu_FullImage" Text="完全全画面"
                                    KeyboardAcceleratorTextOverride="Shift+F"
                                    Click="MenuFullImage_Click" />

                    <MenuFlyoutSeparator />

                    <!-- プレビュー専用群（Opening でプレビュー時のみ有効化） -->
                    <MenuFlyoutSubItem x:Name="PreviewSubItem" x:Uid="Menu_PreviewSub" Text="プレビュー">
                        <ToggleMenuFlyoutItem x:Name="ImmersiveToggleItem" x:Uid="Menu_ImmersiveToggle"
                                              Text="イマーシブ表示"
                                              KeyboardAcceleratorTextOverride="F"
                                              Click="MenuImmersive_Click" />
                        <ToggleMenuFlyoutItem x:Name="InfoToggleItem" x:Uid="Menu_InfoToggle"
                                              Text="メタ情報オーバーレイ"
                                              KeyboardAcceleratorTextOverride="I"
                                              Click="MenuInfo_Click" />
                        <ToggleMenuFlyoutItem x:Name="ExifToggleItem" x:Uid="Menu_ExifToggle"
                                              Text="EXIF 詳細パネル"
                                              KeyboardAcceleratorTextOverride="E"
                                              Click="MenuExif_Click" />
                        <MenuFlyoutItem x:Uid="Menu_GridKind" Text="構図グリッド: 種類を変更"
                                        KeyboardAcceleratorTextOverride="G"
                                        Click="MenuGridKind_Click" />
                        <MenuFlyoutItem x:Uid="Menu_GridRef" Text="構図グリッド: 基準を切替"
                                        KeyboardAcceleratorTextOverride="Shift+G"
                                        Click="MenuGridRef_Click" />
                    </MenuFlyoutSubItem>

                    <MenuFlyoutSeparator />

                    <!-- ファイル連携（Opening で写真選択時のみ有効化。対象＝FocusedPhoto） -->
                    <MenuFlyoutSubItem x:Name="FileSubItem" x:Uid="Menu_FileSub" Text="ファイル">
                        <MenuFlyoutItem x:Uid="Menu_Explorer" Text="エクスプローラーで表示"
                                        KeyboardAcceleratorTextOverride="Ctrl+E"
                                        Click="MenuExplorer_Click" />
                        <MenuFlyoutItem x:Uid="Menu_OpenDefault" Text="既定のアプリで開く"
                                        KeyboardAcceleratorTextOverride="Alt+E"
                                        Click="MenuOpenDefault_Click" />
                        <MenuFlyoutItem x:Uid="Menu_CopyPath" Text="パスをコピー"
                                        KeyboardAcceleratorTextOverride="Ctrl+Alt+E"
                                        Click="MenuCopyPath_Click" />
                        <MenuFlyoutItem x:Uid="Menu_Share" Text="共有"
                                        KeyboardAcceleratorTextOverride="Alt+S"
                                        Click="MenuShare_Click" />
                    </MenuFlyoutSubItem>

                    <MenuFlyoutSeparator />

                    <MenuFlyoutItem x:Uid="Menu_Settings" Text="設定…" Click="MenuSettings_Click" />
                    <MenuFlyoutItem x:Uid="Menu_Shortcuts" Text="ショートカット一覧…"
                                    KeyboardAcceleratorTextOverride="F1"
                                    Click="MenuShortcuts_Click" />
                    <MenuFlyoutItem x:Uid="Menu_About" Text="バージョン情報…" Click="MenuAbout_Click" />
                </MenuFlyout>
            </Button.Flyout>
        </Button>
    </Grid>
</UserControl>
