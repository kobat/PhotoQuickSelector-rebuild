<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PhotoQuickSelector_App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PhotoQuickSelector_App"
    xmlns:vm="using:PhotoQuickSelector_App.ViewModels"
    xmlns:ctl="using:PhotoQuickSelector_App.Controls"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftColumn" Width="300" MinWidth="0" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 左ペイン: お気に入り / 最近 / フォルダツリー（FolderNavigationView へ切り出し済み） -->
        <ctl:FolderNavigationView Grid.Column="0" x:Name="LeftNav" />

        <!-- リサイズ用スプリッター -->
        <controls:GridSplitter
            x:Name="LeftSplitter"
            Grid.Column="1"
            Width="8"
            ResizeBehavior="BasedOnAlignment"
            ResizeDirection="Auto" />

        <!-- 右ペイン: ステータスバー＋サムネイルグリッド／大画面プレビュー（行1で排他表示） -->
        <Grid Grid.Column="2" x:Name="RightPaneRoot" Padding="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ステータスバー（フィルタボタンを内包。開閉は ToggleLeftPaneRequested で受ける） -->
            <ctl:PhotoStatusBar Grid.Row="0" x:Name="StatusBar" Margin="0,0,0,8" />

            <!-- サムネイルグリッド（プレビューとは Visibility で排他） -->
            <ctl:PhotoGridView
                x:Name="ThumbnailGrid"
                Grid.Row="1"
                Visibility="{x:Bind ViewModel.ThumbnailVisibility, Mode=OneWay}" />

            <!-- 大画面プレビュー（サムネイルとは Visibility で排他） -->
            <ctl:PreviewControl
                x:Name="Preview"
                Grid.Row="1"
                Visibility="{x:Bind ViewModel.PreviewVisibility, Mode=OneWay}" />
        </Grid>

        <!-- 左ペインのフライアウト表示（ピン解除時）: LeftNav 自体は再ペアレントせず、ColumnSpan/Width/
             ZIndex の切替だけでオーバーレイ化する（MainPage.xaml.cs の OpenLeftPaneFlyout/CloseLeftPaneFlyout）。 -->
        <!-- ライトディスミス層。クリックで閉じる（Transparent 背景がヒットテストに必須）。 -->
        <Grid x:Name="FlyoutDismissLayer" Grid.Column="0" Grid.ColumnSpan="3"
              Background="Transparent" Visibility="Collapsed" Canvas.ZIndex="10"
              PointerPressed="FlyoutDismissLayer_PointerPressed" />
        <!-- フライアウトの背景板。LeftNav 自体は背景を持たないため下に敷いて不透明化＋右端 1px の境界線。 -->
        <Border x:Name="FlyoutBackdrop" Grid.Column="0" Grid.ColumnSpan="3"
                HorizontalAlignment="Left" Visibility="Collapsed" Canvas.ZIndex="11"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0"
                Translation="0,0,32">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
        </Border>
    </Grid>
</Page>
