<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PhotoQuickSelector_App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PhotoQuickSelector_App"
    xmlns:vm="using:PhotoQuickSelector_App.ViewModels"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftColumn" Width="300" MinWidth="0" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 左ペイン: フォルダツリー -->
        <Grid Grid.Column="0" x:Name="LeftPane" Padding="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <Button x:Name="LoadButton" Click="LoadButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                        <TextBlock Text="読み込み" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <TreeView
                x:Name="FolderTree"
                Grid.Row="1"
                SelectionMode="Single"
                Expanding="FolderTree_Expanding"
                DoubleTapped="FolderTree_DoubleTapped">
                <TreeView.ItemTemplate>
                    <DataTemplate x:DataType="vm:FolderNode">
                        <TreeViewItem ItemsSource="{x:Bind Children}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                                <TextBlock Text="{x:Bind Name}" />
                            </StackPanel>
                        </TreeViewItem>
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

        <!-- リサイズ用スプリッター -->
        <controls:GridSplitter
            Grid.Column="1"
            Width="8"
            ResizeBehavior="BasedOnAlignment"
            ResizeDirection="Auto" />

        <!-- 右ペイン: サムネイル一覧 -->
        <Grid Grid.Column="2" Padding="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ステータスバー -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="ToggleLeftPaneButton_Click" Margin="0,0,8,0"
                        ToolTipService.ToolTip="左ペインの表示/非表示">
                    <FontIcon Glyph="&#xE700;" FontSize="14" />
                </Button>
                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                           Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis" />
                <ProgressRing Grid.Column="2" Width="20" Height="20"
                              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
            </Grid>

            <!-- サムネイルグリッド -->
            <GridView
                x:Name="PhotoGrid"
                Grid.Row="1"
                ItemsSource="{x:Bind ViewModel.Photos, Mode=OneWay}"
                SelectionMode="Single"
                IsItemClickEnabled="False"
                SelectionChanged="PhotoGrid_SelectionChanged"
                KeyDown="PhotoGrid_KeyDown">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PhotoItemViewModel">
                        <Grid Width="200" Height="200" Margin="2"
                              Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                            <Image Source="{x:Bind Thumbnail, Mode=OneWay}" Stretch="Uniform" />

                            <!-- 上部: レーティング / フラグ -->
                            <Grid VerticalAlignment="Top" Padding="4"
                                  Background="#80000000">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" FontSize="14"
                                           Foreground="{x:Bind RatingForeground, Mode=OneWay}"
                                           Text="{x:Bind RatingStars, Mode=OneWay}" />
                                <FontIcon Grid.Column="1" Glyph="&#xE7C1;" FontSize="14"
                                          Foreground="LimeGreen"
                                          Visibility="{x:Bind PickVisibility, Mode=OneWay}" />
                                <FontIcon Grid.Column="1" Glyph="&#xE711;" FontSize="14"
                                          Foreground="OrangeRed"
                                          Visibility="{x:Bind RejectVisibility, Mode=OneWay}" />
                            </Grid>

                            <!-- 下部: ファイル名 / カラーラベル -->
                            <StackPanel VerticalAlignment="Bottom" Padding="4" Spacing="2"
                                        Background="#80000000">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <Ellipse Width="10" Height="10" Fill="#E53935"
                                             Visibility="{x:Bind RedVisibility, Mode=OneWay}" />
                                    <Ellipse Width="10" Height="10" Fill="#FDD835"
                                             Visibility="{x:Bind YellowVisibility, Mode=OneWay}" />
                                    <Ellipse Width="10" Height="10" Fill="#43A047"
                                             Visibility="{x:Bind GreenVisibility, Mode=OneWay}" />
                                    <Ellipse Width="10" Height="10" Fill="#1E88E5"
                                             Visibility="{x:Bind BlueVisibility, Mode=OneWay}" />
                                    <Ellipse Width="10" Height="10" Fill="#8E24AA"
                                             Visibility="{x:Bind PurpleVisibility, Mode=OneWay}" />
                                </StackPanel>
                                <TextBlock Text="{x:Bind FileName}" Foreground="White"
                                           FontSize="11" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</Page>
