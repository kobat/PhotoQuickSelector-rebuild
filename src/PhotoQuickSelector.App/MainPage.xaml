<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PhotoQuickSelector_App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PhotoQuickSelector_App"
    xmlns:vm="using:PhotoQuickSelector_App.ViewModels"
    xmlns:ctl="using:PhotoQuickSelector_App.Controls"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftColumn" Width="300" MinWidth="0" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 左ペイン: お気に入り / 最近 / フォルダツリー -->
        <Grid Grid.Column="0" x:Name="LeftPane" Padding="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                <Button x:Name="LoadButton" Click="LoadButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                        <TextBlock Text="読み込み" />
                    </StackPanel>
                </Button>
                <Button x:Name="RefreshButton" Click="RefreshButton_Click"
                        ToolTipService.ToolTip="選択フォルダを更新 (F5)">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        <TextBlock Text="更新" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- お気に入り -->
            <Expander Grid.Row="1" x:Name="FavoritesExpander"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                      Margin="0,0,0,4" IsExpanded="True"
                      Visibility="{x:Bind ViewModel.FavoritesVisibility, Mode=OneWay}">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE735;" FontSize="14" />
                        <TextBlock Text="お気に入り" />
                    </StackPanel>
                </Expander.Header>
                <ListView ItemsSource="{x:Bind ViewModel.Favorites, Mode=OneWay}"
                          SelectionMode="None" IsItemClickEnabled="True"
                          ItemClick="Shortcut_ItemClick" MaxHeight="180">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:FolderShortcut">
                            <Grid ToolTipService.ToolTip="{x:Bind Path}">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="お気に入りから削除"
                                                        Click="RemoveFavoriteMenuItem_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE738;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE8B7;" FontSize="14"
                                          VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Name}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <Button Grid.Column="2" Click="RemoveFavoriteButton_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="4" MinWidth="0"
                                        VerticalAlignment="Center"
                                        ToolTipService.ToolTip="お気に入りから削除">
                                    <FontIcon Glyph="&#xE711;" FontSize="12" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Expander>

            <!-- 最近開いたフォルダ -->
            <Expander Grid.Row="2" x:Name="RecentExpander"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                      Margin="0,0,0,8" IsExpanded="True"
                      Visibility="{x:Bind ViewModel.RecentVisibility, Mode=OneWay}">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE81C;" FontSize="14" />
                        <TextBlock Text="最近開いたフォルダ" />
                    </StackPanel>
                </Expander.Header>
                <ListView ItemsSource="{x:Bind ViewModel.RecentFolders, Mode=OneWay}"
                          SelectionMode="None" IsItemClickEnabled="True"
                          ItemClick="Shortcut_ItemClick" MaxHeight="220">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:FolderShortcut">
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        ToolTipService.ToolTip="{x:Bind Path}">
                                <StackPanel.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="お気に入りに追加"
                                                        Click="AddFavoriteFromRecentMenuItem_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE735;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="一覧から削除"
                                                        Click="RemoveRecentMenuItem_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE738;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </StackPanel.ContextFlyout>
                                <FontIcon Glyph="&#xE81C;" FontSize="14" />
                                <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Expander>

            <TreeView
                x:Name="FolderTree"
                Grid.Row="3"
                SelectionMode="Single"
                Expanding="FolderTree_Expanding"
                DoubleTapped="FolderTree_DoubleTapped"
                KeyDown="FolderTree_KeyDown">
                <TreeView.ItemTemplate>
                    <DataTemplate x:DataType="vm:FolderNode">
                        <TreeViewItem ItemsSource="{x:Bind Children}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <StackPanel.ContextFlyout>
                                    <MenuFlyout Opening="FolderTreeFlyout_Opening">
                                        <MenuFlyoutItem Text="お気に入りに追加"
                                                        Click="AddFavoriteMenuItem_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE735;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="お気に入りから削除"
                                                        Click="RemoveFavoriteFromTreeMenuItem_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE738;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem Text="更新" Click="RefreshMenuItem_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE72C;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </StackPanel.ContextFlyout>
                                <FontIcon Glyph="&#xE8B7;" FontSize="14" />
                                <TextBlock Text="{x:Bind Name}" />
                            </StackPanel>
                        </TreeViewItem>
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

        <!-- リサイズ用スプリッター -->
        <controls:GridSplitter
            Grid.Column="1"
            Width="8"
            ResizeBehavior="BasedOnAlignment"
            ResizeDirection="Auto" />

        <!-- 右ペイン: サムネイル一覧 -->
        <Grid Grid.Column="2" Padding="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ステータスバー -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="ToggleLeftPaneButton_Click" Margin="0,0,8,0"
                        ToolTipService.ToolTip="左ペインの表示/非表示">
                    <FontIcon Glyph="&#xE700;" FontSize="14" />
                </Button>
                <TextBlock Grid.Column="1" VerticalAlignment="Center"
                           Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis" />
                <ProgressRing Grid.Column="2" Width="20" Height="20"
                              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
            </Grid>

            <!-- サムネイルグリッド -->
            <GridView
                x:Name="PhotoGrid"
                Grid.Row="1"
                Visibility="{x:Bind ViewModel.ThumbnailVisibility, Mode=OneWay}"
                ItemsSource="{x:Bind ViewModel.Photos, Mode=OneWay}"
                SelectionMode="Single"
                IsItemClickEnabled="False"
                SelectionChanged="PhotoGrid_SelectionChanged"
                DoubleTapped="PhotoGrid_DoubleTapped">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="vm:PhotoItemViewModel">
                        <!-- カラーラベル＝枠線。透明時も 3px 確保しレイアウトを安定させる -->
                        <Border Width="200" Height="200" Margin="2"
                                CornerRadius="6" BorderThickness="3"
                                BorderBrush="{x:Bind ColorLabelBorderBrush, Mode=OneWay}">
                            <Grid Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                <Image Source="{x:Bind Thumbnail, Mode=OneWay}" Stretch="Uniform" />

                                <!-- 旗バッジ（左上）：採用=旗 / 拒否=×。正方形 -->
                                <Border VerticalAlignment="Top" HorizontalAlignment="Left"
                                        Margin="6" Width="30" Height="30" CornerRadius="4"
                                        Background="#99000000"
                                        Visibility="{x:Bind FlagVisibility, Mode=OneWay}">
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE7C1;" FontSize="16" Foreground="LimeGreen"
                                                  Visibility="{x:Bind PickVisibility, Mode=OneWay}" />
                                        <FontIcon Glyph="&#xE711;" FontSize="16" Foreground="OrangeRed"
                                                  Visibility="{x:Bind RejectVisibility, Mode=OneWay}" />
                                    </Grid>
                                </Border>

                                <!-- 色ドット（右上）：高さは旗と同じ、単一色は正方形 -->
                                <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                        Margin="6" Height="30" MinWidth="30" Padding="6,0" CornerRadius="4"
                                        Background="#99000000"
                                        Visibility="{x:Bind ColorDotsVisibility, Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="4"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse Width="15" Height="15" Fill="#E53935"
                                                 Visibility="{x:Bind RedVisibility, Mode=OneWay}" />
                                        <Ellipse Width="15" Height="15" Fill="#FDD835"
                                                 Visibility="{x:Bind YellowVisibility, Mode=OneWay}" />
                                        <Ellipse Width="15" Height="15" Fill="#43A047"
                                                 Visibility="{x:Bind GreenVisibility, Mode=OneWay}" />
                                        <Ellipse Width="15" Height="15" Fill="#1E88E5"
                                                 Visibility="{x:Bind BlueVisibility, Mode=OneWay}" />
                                        <Ellipse Width="15" Height="15" Fill="#8E24AA"
                                                 Visibility="{x:Bind PurpleVisibility, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>

                                <!-- 下部: ★レーティング（中央, 色ドットと同形の黒バッジ）／ファイル名（黒帯, 常時） -->
                                <StackPanel VerticalAlignment="Bottom" Spacing="2">
                                    <Border HorizontalAlignment="Center"
                                            Height="30" MinWidth="30" Padding="6,0" CornerRadius="4"
                                            Background="#99000000"
                                            Visibility="{x:Bind RatingVisibility, Mode=OneWay}">
                                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Foreground="{x:Bind RatingForeground, Mode=OneWay}"
                                                   Text="{x:Bind RatingStars, Mode=OneWay}" />
                                    </Border>
                                    <Border Background="#80000000" Padding="6,4">
                                        <TextBlock Text="{x:Bind FileName}" Foreground="White"
                                                   FontSize="11" TextTrimming="CharacterEllipsis" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>

            <!-- 大画面プレビュー（サムネイルとは Visibility で排他） -->
            <ctl:PreviewControl
                x:Name="Preview"
                Grid.Row="1"
                Visibility="{x:Bind ViewModel.PreviewVisibility, Mode=OneWay}" />
        </Grid>
    </Grid>
</Page>
