<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="PhotoQuickSelector_App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PhotoQuickSelector_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PhotoQuickSelector.App"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <!--
        システム標準タイトルバーを使用（コードビハインドで ExtendsContentIntoTitleBar=false）。
        ×が画像操作後に1回で閉じない問題を避けるため、カスタムタイトルバーは採用しない。
        RootGrid はキー入力集約（RootGrid_PreviewKeyDown）の土台として残す。
        Frame がアプリ本体（MainPage）をホストする。
    -->
    <Grid x:Name="RootGrid">
        <Frame x:Name="RootFrame" />
    </Grid>
</Window>
