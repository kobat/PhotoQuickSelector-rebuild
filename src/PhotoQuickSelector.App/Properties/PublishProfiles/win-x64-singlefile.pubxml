<?xml version="1.0" encoding="utf-8"?>
<!--
  配布プロファイル（B）: unpackaged 自己完結 ＋ 単一ファイル EXE
  - PublishSingleFile=true                 : 1 個の巨大 exe にまとめる
  - IncludeNativeLibrariesForSelfExtract   : SQLite.Interop.dll / Win2D / WinAppSDK ネイティブを
                                             exe 内へ取り込み、初回起動時に自己展開
  既知の制約（SPEC §0）:
    - 完全な単一ファイルにはならず resources.pri 等が隣に残る（「巨大 exe ＋ 数ファイル」前提）
    - 初回起動でネイティブ DLL を展開するため、ひと呼吸の遅延あり
    - exe サイズは概ね 150〜250MB
  発行例:
    dotnet publish -c Release -p:Platform=x64 -p:PublishProfile=win-x64-singlefile
  https://go.microsoft.com/fwlink/?LinkID=208121.
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishDir>bin\$(Configuration)\$(TargetFramework)\$(RuntimeIdentifier)\publish-singlefile\</PublishDir>
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <PublishReadyToRun>true</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
